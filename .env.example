TRAVEL_AGENT_HTTP_ADDR=:8080
TRAVEL_AGENT_PLANNER=eino

TRAVEL_AGENT_REDIS_ADDR=localhost:6379
TRAVEL_AGENT_REDIS_PASSWORD=
TRAVEL_AGENT_REDIS_DB=0
TRAVEL_AGENT_CACHE_TTL_SECONDS=1800
TRAVEL_AGENT_REDIS_LOCK_TTL_SECONDS=15
TRAVEL_AGENT_RATE_LIMIT_PER_MINUTE=60

TRAVEL_AGENT_SQL_ENABLED=false
TRAVEL_AGENT_SQL_DSN=
TRAVEL_AGENT_SQL_MAX_OPEN_CONNS=10
TRAVEL_AGENT_SQL_MAX_IDLE_CONNS=5
TRAVEL_AGENT_SQL_CONN_MAX_LIFETIME_SECONDS=1800

TRAVEL_AGENT_LLM_ENABLED=true
TRAVEL_AGENT_LLM_PROVIDER=deepseek
TRAVEL_AGENT_LLM_BASE_URL=https://api.deepseek.com/beta
TRAVEL_AGENT_LLM_MODEL=deepseek-v4-flash
TRAVEL_AGENT_LLM_MODEL_QUICK=deepseek-v4-flash
TRAVEL_AGENT_LLM_MODEL_EXPERT=deepseek-v4-pro
TRAVEL_AGENT_LLM_STREAM_ENABLED=true
TRAVEL_AGENT_LLM_API_KEY=

TRAVEL_AGENT_TOOL_MODE=real
TRAVEL_AGENT_AMAP_API_KEY=
TRAVEL_AGENT_EXTERNAL_API_CONCURRENCY=2
TRAVEL_AGENT_EXTERNAL_API_QPS=2

TRAVEL_AGENT_AUTH_ENABLED=true
TRAVEL_AGENT_SESSION_COOKIE_NAME=travel_agent_session
TRAVEL_AGENT_SESSION_TTL_HOURS=168
TRAVEL_AGENT_PASSWORD_MIN_LENGTH=8
TRAVEL_AGENT_PUBLIC_PLAN_PAGE_SIZE=20
# Anonymous generation defaults to false. Local devs without an account can flip
# this to true to keep the legacy anonymous flow working.
TRAVEL_AGENT_ALLOW_ANONYMOUS_PLAN_GENERATION=false
TRAVEL_AGENT_COOKIE_SECURE=false
TRAVEL_AGENT_COOKIE_DOMAIN=
# Comma-separated list of origins that may send credentialed requests.
TRAVEL_AGENT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
