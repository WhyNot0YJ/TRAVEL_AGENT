TRAVEL_AGENT_SQL_CONN_MAX_LIFETIME_SECONDS=1800

TRAVEL_AGENT_AUTH_ENABLED=true
TRAVEL_AGENT_ALLOW_ANONYMOUS_PLAN_GENERATION=true
